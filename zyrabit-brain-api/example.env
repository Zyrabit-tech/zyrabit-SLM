# Zyrabit Brain API - Environment Variables
# Copy to .env and adjust values:
#   cp example.env .env

# --- Required: Core Stack ---
# Inference provider options:
# - ollama (default)
# - ollama_host
# - ollama_docker
# - openai_compatible
INFERENCE_PROVIDER=ollama
SLM_URL=http://slm-engine:11434/api/generate
DB_URL=http://vector-db:8000
MODEL_NAME=qwen2.5:7b
INFERENCE_TIMEOUT_SECONDS=120

# For openai_compatible providers
# INFERENCE_BASE_URL=http://localhost:8000/v1/chat/completions
# INFERENCE_API_KEY=

# --- Required: Observability (Traefik Basic Auth) ---
# Las variables contienen un HASH, no la contraseña en texto plano.
# Para acceder a /prometheus y /grafana: usuario=admin, contraseña=changeme
# No hace falta generar nuevas; las de abajo funcionan. Para cambiar: htpasswd -nbB admin 'tu-password'
# IMPORTANTE: Usar comillas simples para que Docker Compose no interprete los $ del hash bcrypt como variables.
PROMETHEUS_BASIC_AUTH='admin:$2y$05$LoszVeOlLfBI4CdVxATZZ.9yHl10rudfmIsO.wAeSCOjpgCccVoiC'
GRAFANA_BASIC_AUTH='admin:$2y$05$LoszVeOlLfBI4CdVxATZZ.9yHl10rudfmIsO.wAeSCOjpgCccVoiC'

# --- Optional: RAG / Embeddings ---
EMBEDDING_MODEL=mxbai-embed-large
RAG_COLLECTION=zyrabit_knowledge
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Optional: n8n Integration ---
# Para el workflow de ejemplo: usa zyrabit-service-token (o cambia en n8n_zyrabit_webhook_workflow.json)
N8N_SERVICE_TOKEN=zyrabit-service-token
N8N_WEBHOOK_SIGNING_SECRET=zyrabit-webhook-secret
N8N_REQUIRE_SIGNATURE=false
